# SPDX-License-Identifier: GPL-2.0-only
#
# Kernel config tweaks for the Diamond Technologies STM32MP25 DEC kit.
# Merged from the previous cargt 00395 + 00365 fragments.

# Debug aids
# CONFIG_LOGO is not set
CONFIG_KALLSYMS=y
CONFIG_KALLSYMS_ALL=y
CONFIG_DEBUG_INFO=y
# CONFIG_DEBUG_INFO_REDUCED is not set

# RTCs on the SOM / carrier
CONFIG_RTC_DRV_RV3032=y
CONFIG_RTC_DRV_RX8111=m

# 2.8" SPI display (GLT028240320IS1-CTP)
CONFIG_TINYDRM_ST7789T3=y

# 5.5" MIPI DSI display (GLT0557201280IS1-CTP)
CONFIG_TOUCHSCREEN_ILITEK=y
CONFIG_DRM_PANEL_ILITEK_ILI9881C=y

# 10.1" LVDS display (GLT1011280800IS1-CTP) backed by MAX25221 PMIC
CONFIG_SENSORS_MAX25221=y
CONFIG_MFD_MAX25221=y
CONFIG_REGULATOR_MAX25221=y

# SN65DSI83 LVDS bridge support
CONFIG_DRM_TI_SN65DSI83=y
