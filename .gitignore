# u-boot's external-DT build drops compiled DTBs and dtc/cpp scratch
# files into the project tree we ship under dec-stm32mp25-kit/. Those
# are build artifacts — only the .dts/.dtsi/.h/Makefile sources belong
# in the repo.
dec-stm32mp25-kit/**/*.dtb
dec-stm32mp25-kit/**/.*.tmp
dec-stm32mp25-kit/**/.*.cmd
dec-stm32mp25-kit/**/.*.d
dec-stm32mp25-kit/**/.*.pre.tmp
dec-stm32mp25-kit/**/.*.dts.tmp
dec-stm32mp25-kit/**/.*.dtc.tmp

# setup_dec_stm32.sh creates a per-machine EULA symlink at runtime
# (pointing into meta-st-stm32mp's ST_EULA_SLA). It's a checkout-tree
# artifact, not source — keep it out of the repo.
conf/eula/
